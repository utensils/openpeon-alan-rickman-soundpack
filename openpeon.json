        {
          "file": "sounds/task_error_02.mp3",
          "label": "Something has gone rather sideways, I'm afraid."
        },
        {
          "file": "sounds/task_error_03.mp3",
          "label": "An obstacle. Most inconvenient."
        },
        {
          "file": "sounds/task_error_04.mp3",
          "label": "I regret to inform you — it did not go to plan."
        }
      ]
